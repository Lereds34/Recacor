{
  "crons": [
    {
      "path": "/api/cron/publish-articles",
      "schedule": "0 6,12 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "recacor.fr" }],
      "destination": "https://www.recacor.fr/$1",
      "permanent": true
    }
  ]
}
