# ─── Neon Postgres ───
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── Auth admin ───
ADMIN_USER=admin
ADMIN_PASS=change_this_strong_password
AUTH_SECRET=generate-a-random-32-char-string-here-for-jwt-signing

# ─── Vercel Blob (upload images) ───
# Récupérer sur Vercel dashboard → Storage → Blob → Token
BLOB_READ_WRITE_TOKEN=

# ─── Email transactionnel ───
# Brevo (ex-Sendinblue) — priorité si défini
BREVO_API_KEY=
BREVO_SENDER_NAME=Recacor
BREVO_SENDER_EMAIL=noreply@recacor.fr
# Resend — fallback si Brevo absent
RESEND_API_KEY=
RESEND_FROM=Recacor <noreply@recacor.fr>

# ─── Mailchimp (audience auto-add depuis formulaires) ───
# Format: <hex32>-<datacenter>, ex: abc...123-us9
# Récupérer dans Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=

# ─── Google Tag Manager ───
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
